<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /portfolio/

    # Don't rewrite if file or directory exists
    RewriteCond %{REQUEST_FILENAME} !-f
    
    # Don't rewrite system, application, assets folders, and actual files
    RewriteCond %{REQUEST_URI} !^/portfolio/(system|application|assets)/ [NC]
    RewriteCond %{REQUEST_URI} !^/portfolio/\. [NC]
    
    # Rewrite everything else to index.php
    RewriteRule ^(.*)$ index.php/$1 [L]
</IfModule>
